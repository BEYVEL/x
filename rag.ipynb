"""
Minimal RAG System - No dependency conflicts
Run this in a fresh notebook with the new kernel
"""

import os
import numpy as np
import json
import hashlib
from pathlib import Path
import subprocess
from typing import List, Dict, Optional

class CleanRAG:
    """RAG system with minimal dependencies - only numpy and ollama"""
    
    def __init__(self, model_name="gemma:2b"):
        self.model_name = model_name
        self.chunks = []
        self.embeddings = None
        self.sources = []
        
  
        try:
            subprocess.run(["ollama", "list"], capture_output=True, check=True)
            print(f"✅ Ollama найдена с моделью: {model_name}")
        except:
            print("⚠️  Ollama не найдена. пожалуйста установите https://ollama.com")
            print("   Then run: ollama pull gemma:2b")
        
        self.docs_folder = "./my_documents"
        os.makedirs(self.docs_folder, exist_ok=True)
        
        print("✅ CleanRAG готов")
        print(f"📁 Place .txt files in: {self.docs_folder}")
    
    def _hash_features(self, text: str, dim: int = 256) -> np.ndarray:
        """Create hash-based features (no ML dependencies)"""
        words = text.lower().split()[:100]
        features = np.zeros(dim)
        
        for word in words:
            idx = int(hashlib.md5(word.encode()).hexdigest(), 16) % dim
            features[idx] += 1
        
        norm = np.linalg.norm(features)
        if norm > 0:
            features = features / norm
        
        return features
    
    def add_text(self, text: str, source: str = "document"):
        """Add text to knowledge base"""
        chunk_size = 500
        overlap = 50
        
        chunks = []
        sources = []
        
        for i in range(0, len(text), chunk_size - overlap):
            chunk = text[i:i + chunk_size].strip()
            if chunk and len(chunk) > 50:
                chunks.append(chunk)
                sources.append(source)
        
        if not chunks:
            print("⚠️ чанки не созданы")
            return 0
        
        print(f"🔄 идет генерация {len(chunks)} chunks...")
        new_embeddings = np.array([self._hash_features(chunk) for chunk in chunks])
        
        start_idx = len(self.chunks)
        self.chunks.extend(chunks)
        self.sources.extend(sources)
        
        if self.embeddings is None:
            self.embeddings = new_embeddings
        else:
            self.embeddings = np.vstack([self.embeddings, new_embeddings])
        
        print(f"✅ Added {len(chunks)} chunks. Total: {len(self.chunks)}")
        return len(chunks)
    
    def add_file(self, filepath: str):
        """Add a text file"""
        try:
            with open(filepath, 'r', encoding='utf-8') as f:
                text = f.read()
            return self.add_text(text, source=os.path.basename(filepath))
        except Exception as e:
            print(f"❌ ошибка в чтении {filepath}: {e}")
            return 0
    
    def search(self, query: str, k: int = 3):
        """Find most relevant chunks"""
        if not self.chunks:
            return []
        
        query_features = self._hash_features(query)
        
        similarities = np.dot(self.embeddings, query_features)
        
        top_indices = np.argsort(similarities)[-k:][::-1]
        
        results = []
        for idx in top_indices:
            results.append({
                'text': self.chunks[idx],
                'source': self.sources[idx],
                'similarity': float(similarities[idx])
            })
        
        return results
    
    def ask_ollama(self, prompt: str) -> str:
        """Query Ollama directly"""
        try:
            process = subprocess.Popen(
                ['ollama', 'run', self.model_name],
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True
            )
            
            stdout, stderr = process.communicate(input=prompt, timeout=30)
            
            if process.returncode == 0:
                return stdout.strip()
            else:
                return f"Error: {stderr}"
        except subprocess.TimeoutExpired:
            process.kill()
            return "Error: Query timed out"
        except Exception as e:
            return f"Error: {str(e)}"
    
    def query(self, question: str, k: int = 3, show_context: bool = False):
        """Ask a question"""
        relevant = self.search(question, k=k)
        
        if not relevant:
            return "Релевантная информация не найдена."
    
        context_parts = []
        for i, r in enumerate(relevant):
            context_parts.append(f"[Document {i+1} - {r['source']}]:\n{r['text']}")
        
        context = "\n\n---\n\n".join(context_parts)
        
        if show_context:
            print("\n" + "="*50)
            print("📖 Найденный контекст T:")
            print("="*50)
            for r in relevant:
                preview = r['text'][:150] + "..." if len(r['text']) > 150 else r['text']
                print(f"\n📄 {r['source']} (score: {r['similarity']:.3f}):")
                print(f"   {preview}")
            print("="*50)
        
        # Create prompt
        prompt = f"""Answer the question based ONLY on the context below.
If the context doesn't contain the answer, say "I don't have information about that"

CONTEXT:
{context}

QUESTION: {question}

ANSWER:"""
        
        return self.ask_ollama(prompt)
    
    def interactive(self):
        """Interactive Q&A session"""
        print("\n" + "="*60)
        print("🤖 CleanRAG Interactive Session")
        print("="*60)
        print(f"📚 Documents: {len(self.chunks)} chunks")
        print("Commands: /quit, /stats")
        print("-"*60)
        
        while True:
            question = input("\n❓ Your question: ").strip()
            
            if question.lower() == '/quit':
                print("👋 Goodbye!")
                break
            elif question.lower() == '/stats':
                print(f"\n📊 Statistics:")
                print(f"   - Total chunks: {len(self.chunks)}")
                print(f"   - Unique sources: {len(set(self.sources))}")
                continue
            elif not question:
                continue
            
            print("\n🔍 Searching...")
            answer = self.query(question, show_context=True)
            print(f"\n💬 Answer:\n{answer}\n")

# Test the system
print("🚀 Creating RAG system...")
rag = CleanRAG(model_name="gemma:2b")

